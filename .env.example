# Morrigan — Variables d'environnement
# Copier en .env et remplir les valeurs

# Supabase (DANANN — mémoire vectorielle)
SUPABASE_URL=
SUPABASE_KEY=

# Telegram (Interface)
MORRIGAN_TELEGRAM_TOKEN=

# HuggingFace (embeddings model download)
HF_TOKEN=

# Danann — index compressé persisté (optionnel)
# Si défini, le runtime (CLI + bot) charge cet index au démarrage au lieu
# de réembedder data/knowledge. Le dossier doit contenir corpus.json +
# vectors.npz, produits par scripts/build_compressed_index.py ou
# scripts/ingest_wikipedia.py. Sinon, fallback sur data/knowledge.
MORRIGAN_INDEX=

# ── API HTTP (interfaces/api.py) ────────────────────────────────────────
# Bind. Par défaut 127.0.0.1 : exposer sur le réseau est un choix explicite
# (mettre 0.0.0.0), à accompagner d'une clé API et/ou d'un reverse proxy.
MORRIGAN_API_HOST=127.0.0.1
MORRIGAN_API_PORT=8000
# Clé API optionnelle. Si définie, /query, /query/stream et /stats exigent
# l'en-tête `X-API-Key: <valeur>`. /health reste ouvert (sonde de vivacité).
MORRIGAN_API_KEY=
# Générations RWKV simultanées max (CPU-bound) ; au-delà → HTTP 503.
MORRIGAN_API_MAX_CONCURRENT=2
# Bornes d'entrée (anti-DoS) : longueur max de `query` et de `session_id`.
MORRIGAN_API_MAX_QUERY_CHARS=4000
MORRIGAN_API_MAX_SESSION_CHARS=128
