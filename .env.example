# Morrigan — Variables d'environnement
# Copier en .env et remplir les valeurs

# Supabase (DANANN — mémoire vectorielle)
SUPABASE_URL=
SUPABASE_KEY=

# Telegram (Interface)
MORRIGAN_TELEGRAM_TOKEN=

# HuggingFace (embeddings model download)
HF_TOKEN=

# Danann — index compressé persisté (optionnel)
# Si défini, le runtime (CLI + bot) charge cet index au démarrage au lieu
# de réembedder data/knowledge. Le dossier doit contenir corpus.json +
# vectors.npz, produits par scripts/build_compressed_index.py ou
# scripts/ingest_wikipedia.py. Sinon, fallback sur data/knowledge.
MORRIGAN_INDEX=

# ── Retrieval (post-audit 2026-06-12, cf. docs/audit-retrieval-2026-06-12.md) ──
# ANN : "flat" (scan complet, défaut) ou "ivf" (sous-linéaire ; recall@5
# 0.925 @ ~6 ms mesuré sur 46k chunks, vs 56 ms en flat).
MORRIGAN_ANN=flat
# Nb de cellules IVF sondées par requête (vide = heuristique ~C/8).
# Mesuré sur 46k chunks : 26 → recall 0.925 ; 64 → recall 0.988 @ 13 ms.
MORRIGAN_IVF_PROBES=
# Reranker cross-encoder : ON par défaut depuis la Phase 2D (modèle
# multilingue mmarco, fenêtre 16, troncature 1000) — gain FR mesuré
# hit@3 48/56 vs 43/56 (scripts/eval_rag.py), gate strict tenu, pour
# ~1.8 s/req CPU (vs ~12 s de génération). Téléchargement du modèle
# (~135 Mo) au premier usage ; échec de chargement → dégradation propre
# (candidats non re-classés). "off" pour désactiver (ex. retrieval
# standalone où la latence prime).
MORRIGAN_RERANKER=on
# Mini-RAG fragmenté : clé de métadonnée pour partitionner l'index.
# Défaut (et valeur si vide) = "language" → ON. Recherche restreinte au
# shard routé (centroïde top-1, repli monolithique si quasi-égalité).
# Mesuré : 15/16 bonnes réponses vs 13/16 en monolithique, 0 erreur de
# routage — corrige les pièges cross-langage (« trier un tableau en JS »
# → <table> HTML). Sans effet (désactivation propre) si l'index n'a pas
# la clé ou n'est pas compressé int8/binary. "off" pour désactiver.
MORRIGAN_SHARD_BY=language
# Seuil de pertinence du gate RAG strict (cosinus pur, vide = défaut du
# code : 0.84, calibré pour multilingual-e5 sur scripts/eval_rag.py —
# in-corpus 52/56 passants, hors-corpus 20/24 refusés). À recalibrer via
# `eval_rag.py --sweep` après tout changement d'embedder ou de corpus.
MORRIGAN_MIN_RELEVANCE=

# ── API HTTP (interfaces/api.py) ────────────────────────────────────────
# Bind. Par défaut 127.0.0.1 : exposer sur le réseau est un choix explicite
# (mettre 0.0.0.0), à accompagner d'une clé API et/ou d'un reverse proxy.
MORRIGAN_API_HOST=127.0.0.1
MORRIGAN_API_PORT=8000
# Clé API optionnelle. Si définie, /query, /query/stream et /stats exigent
# l'en-tête `X-API-Key: <valeur>`. /health reste ouvert (sonde de vivacité).
MORRIGAN_API_KEY=
# Générations RWKV simultanées max (CPU-bound) ; au-delà → HTTP 503.
MORRIGAN_API_MAX_CONCURRENT=2
# Bornes d'entrée (anti-DoS) : longueur max de `query` et de `session_id`.
MORRIGAN_API_MAX_QUERY_CHARS=4000
MORRIGAN_API_MAX_SESSION_CHARS=128
