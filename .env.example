# Morrigan — Variables d'environnement
# Copier en .env et remplir les valeurs

# Supabase (DANANN — mémoire vectorielle)
SUPABASE_URL=
SUPABASE_KEY=

# Telegram (Interface)
MORRIGAN_TELEGRAM_TOKEN=

# HuggingFace (embeddings model download)
HF_TOKEN=

# Danann — index compressé persisté (optionnel)
# Si défini, le runtime (CLI + bot) charge cet index au démarrage au lieu
# de réembedder data/knowledge. Le dossier doit contenir corpus.json +
# vectors.npz, produits par scripts/build_compressed_index.py ou
# scripts/ingest_wikipedia.py. Sinon, fallback sur data/knowledge.
MORRIGAN_INDEX=
